# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://ats_user:ats_pass@localhost:5432/ats_db

# ── Auth ──────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=8h

# ── OpenAI API ─────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── App ───────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ── File Upload ───────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5

# ── Email (SMTP) ───────────────────────────────────────────
# Leave SMTP_HOST blank in development to use Ethereal (fake SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="ATS Platform <noreply@myats.dev>"

# ── Welfare Check Cron ─────────────────────────────────────
WELFARE_CRON_ENABLED=true

# ── Microsoft / OneDrive OAuth (Provider Spreadsheet Sync) ─
FRONTEND_URL=http://localhost:5173
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret
AZURE_TENANT_ID=common
MS_REDIRECT_URI=https://your-api-host/api/ms-auth/callback
TOKEN_ENCRYPTION_KEY=64-char-hex-string-from-node-crypto
